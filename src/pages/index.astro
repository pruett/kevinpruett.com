---
import Head from '../components/Head.astro'
import Header from '../components/Header.astro'
import Main from '../components/Main.astro'
import Footer from '../components/Footer.astro'
---

<style>
    .container {
        display: grid;
        grid-template-columns: 1fr min(85rem, calc(100% - 8rem)) 1fr;
        grid-column-gap: 4rem;
    }

    /* There seems to be a bug in Astro's CSS parsing */
    /* That prevents this rule from working without the :global identifier */
    :global(.container > *) {
        grid-column: 2;
    }
</style>

<!doctype html>
<html lang="en-US">
    <Head />
    <body>
        <div class="container">
            <Header />
            <Main />
            <Footer />
        </div>
    </body>
</html>
