---
import Head from '../components/Head.astro'
import Header from '../components/Header.astro'
---

<style>
    .grid {
        display: grid;
        grid-template-columns: 1fr min(85ch, calc(100% - 4rem)) 1fr;
        grid-column-gap: 2rem;
    }

    /* There seems to be a bug in Astro's CSS parsing */
    /* That prevents this rule from working without the :global identifier */
    :global(.grid > *) {
        grid-column: 2;
    }

    @media (prefers-color-scheme: dark) {
        body {
            background: var(--background-color-dark);
            color: var(--color-white);
        }
    }
</style>

<!DOCTYPE html>
<html lang="en-US">
    <Head />
    <body>
        <div class="grid">
            <div style="text-align:center;">
                Nothing to see here...
            </div>
        </div>
    </body>
</html>
